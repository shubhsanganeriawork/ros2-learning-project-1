<?xml version="1.0"?>
<launch>

    <let name="urdf_path"
         value="$(find-pkg-share udemy_robo1_description)/urdf/first_robo.xacro" />
    <let name="gazebo_config_path"
         value="$(find-pkg-share robot_bringup)/config/gazebo_bridge.yaml"/>
    <let name="rviz_config_path"
         value="$(find-pkg-share udemy_robo1_description)/rviz/urdf_config.rviz" />
    <let name="custom_world_path"
         value="$(find-pkg-share robot_bringup)/worlds/custom_world_1.sdf"/>


    <node pkg="robot_state_publisher"
          exec="robot_state_publisher"
          name="robot_state_publisher">

        <param name="robot_description"
               value="$(command 'xacro $(var urdf_path)')" />
    </node>

    <node pkg="joint_state_publisher"
          exec="joint_state_publisher"
          name="joint_state_publisher"/>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="$(var custom_world_path) -r" />
    </include>

    <node pkg="ros_gz_sim" exec="create" args="-topic robot_description" />

    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(var gazebo_config_path)" />
    </node>

    <node pkg="rviz2"
        exec="rviz2"
        output="screen"
        args="-d $(var rviz_config_path)" />

</launch>