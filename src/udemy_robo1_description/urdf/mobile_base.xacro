<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="base_length" value="0.6" />
    <xacro:property name="base_width" value="0.4" />
    <xacro:property name="base_height" value="0.2" />
    <xacro:property name="wheel_radius" value="0.1" />
    <xacro:property name="wheel_length" value="0.05" />

    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder length="${wheel_length}" radius="${wheel_radius}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <material name="blue" />
            </visual>

            <collision>
                <geometry>
                    <sphere radius="${wheel_radius}" />
                </geometry>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            </collision>

            <xacro:sphere_inertial mass="1.0" r="${wheel_radius}" o_xyz="0 0 0" o_rpy="${pi / 2.0} 0 0"/>
        </link>
    </xacro:macro>

    <!--                  LINKS                  -->

    <link name="base_footprint"/>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="black" />
        </visual>

        <xacro:box_inertial mass="5.0" l="${base_length}" w="${base_width}" h="${base_height}" o_xyz="0 0 0" o_rpy="0 0 0"/>

        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </collision>

    </link>

    <xacro:wheel_link prefix="right" />
    <xacro:wheel_link prefix="left" />

    <link name="caster_wheel">
        <visual>
            <geometry>
                <sphere radius="${wheel_radius/2}" />
            </geometry>
            <material name="green" />
        </visual>

        <xacro:sphere_inertial mass="1.0" r="${wheel_radius/2}" o_xyz="0 0 0" o_rpy="0 0 0" />

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <sphere radius="${wheel_radius/2}" />
            </geometry>
        </collision>
        
    </link>

    <!--                  JOINTS                  -->

    <joint name="base_footprint_base_link" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0 0 ${base_height/2 + wheel_radius}" rpy="0 0 0" />
    </joint>

    <joint name="base_link_right_wheel" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_link" />
        <origin xyz="${-base_length/4} ${-(base_width/2 + wheel_length)} ${-base_height/2}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_link_left_wheel" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_link" />
        <origin xyz="${-base_length/4} ${(base_width/2 + wheel_length)} ${-base_height/2}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_link_caster_wheel" type="fixed">
        <parent link="base_link" />
        <child link="caster_wheel" />
        <origin xyz="${base_length/3.0} 0 ${-(base_height/2 + wheel_radius/2)}" rpy="0 0 0" />
    </joint>

</robot>